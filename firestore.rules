rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function signedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }
    
    function isPermanentAdminEmail() {
      return signedIn() && request.auth.token.email in [
        "nilay2103@gmail.com",
        "nilayaws21@gmail.com"
      ];
    }
    
    function isAdminUser() {
      return isPermanentAdminEmail() || (
        signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdminUser();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdminUser();
    }

    match /reports/{reportId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAdminUser()
        || (signedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdminUser();
    }

    match /timeline/{timelineId} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isAdminUser();
    }

    match /validations/{validationId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdminUser();
    }

    match /clusters/{clusterId} {
      allow read: if true;
      allow create, update: if signedIn();
      allow delete: if isAdminUser();
    }

    match /escalations/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdminUser();
    }

    match /resolutionChecks/{id} {
      allow read: if true;
      allow create, update, delete: if isAdminUser();
    }
  }
}

